<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
  version="5.0">

	<!-- Servlets -->
  <servlet>
    <servlet-name>greetServlet</servlet-name>
    <servlet-class>it.unibo.GreetingServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>greetServlet</servlet-name>
    <url-pattern>/app/greet</url-pattern>
  </servlet-mapping>
  

  <servlet>
    <servlet-name>ingredentiServlet</servlet-name>
    <servlet-class>it.unibo.IngredientiServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ingredentiServlet</servlet-name>
    <url-pattern>/app/ingredienti</url-pattern>
  </servlet-mapping>


  <!-- Authentication (login / registration) -->
  <servlet>
    <servlet-name>authServlet</servlet-name>
    <servlet-class>it.unibo.AuthServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>authServlet</servlet-name>
    <url-pattern>/app/auth</url-pattern>
  </servlet-mapping>

  <!-- Announcements -->
  <servlet>
    <servlet-name>announcementServlet</servlet-name>
    <servlet-class>it.unibo.AnnouncementServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>announcementServlet</servlet-name>
    <url-pattern>/app/announcements</url-pattern>
  </servlet-mapping>

  <!-- Profile management -->
  <servlet>
    <servlet-name>profileServlet</servlet-name>
    <servlet-class>it.unibo.ProfileServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>profileServlet</servlet-name>
    <url-pattern>/app/profile</url-pattern>
  </servlet-mapping>

  <!-- Exchange requests -->
  <servlet>
    <servlet-name>exchangeServlet</servlet-name>
    <servlet-class>it.unibo.ExchangeServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>exchangeServlet</servlet-name>
    <url-pattern>/app/exchanges</url-pattern>
  </servlet-mapping>

  <!-- Internal chat -->
  <servlet>
    <servlet-name>chatServlet</servlet-name>
    <servlet-class>it.unibo.ChatServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>chatServlet</servlet-name>
    <url-pattern>/app/chat</url-pattern>
  </servlet-mapping>

  <!-- Reviews / reputation -->
  <servlet>
    <servlet-name>reviewServlet</servlet-name>
    <servlet-class>it.unibo.ReviewServiceImpl</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>reviewServlet</servlet-name>
    <url-pattern>/app/reviews</url-pattern>
  </servlet-mapping>

  <!-- Federation inbox (server-to-server, not GWT RPC) -->
  <servlet>
    <servlet-name>federationInbox</servlet-name>
    <servlet-class>it.unibo.FederationInboxServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>federationInbox</servlet-name>
    <url-pattern>/federation/inbox</url-pattern>
  </servlet-mapping>

  <!-- Manual federation outbox retry trigger (server-to-server/admin HTTP) -->
  <servlet>
    <servlet-name>federationRetry</servlet-name>
    <servlet-class>it.unibo.FederationRetryServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>federationRetry</servlet-name>
    <url-pattern>/federation/retry</url-pattern>
  </servlet-mapping>

  <!-- Application-wide automatic retry for persisted federation events -->
  <listener>
    <listener-class>it.unibo.FederationRetryLifecycleListener</listener-class>
  </listener>

	<!-- Default page to serve -->
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>

</web-app>
